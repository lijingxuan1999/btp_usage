# BTP Usage Analytics Service (UAS) Reporting API
BTP_UAS_URL=https://uas-reporting.cfapps.<region>.hana.ondemand.com

# XSUAA token endpoint
BTP_AUTH_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token

# OAuth2 Client Credentials (from BTP Service Key)
BTP_CLIENT_ID=<your-client-id>
BTP_CLIENT_SECRET=<your-client-secret>

# BTP Subaccount GUID
BTP_SUBACCOUNT_ID=<your-subaccount-guid>

# BTP Global Account GUID
BTP_GLOBAL_ACCOUNT_ID=<your-global-account-guid>

# ── SAP HANA Cloud Metering & Metrics APIs ───────────────────────────────────
# Landscape region (e.g. prod-eu10, prod-us10, prod-ap10 — see OpenAPI spec for full list)
HANA_REGION=prod-eu10

# XSUAA token endpoint for HANA Cloud monitoring credentials
HANA_AUTH_URL=https://<landscape>.authentication.sap.hana.ondemand.com/oauth/token

# OAuth2 Client Credentials (from HANA Cloud service key with Monitoring.Read scope)
HANA_CLIENT_ID=<your-hana-client-id>
HANA_CLIENT_SECRET=<your-hana-client-secret>

# Default HANA Cloud service instance GUID (can be overridden per tool call)
HANA_SERVICE_INSTANCE_ID=<your-hana-service-instance-guid>

# ── SAP AI Core (LLM backend) ──────────────────────────────────────────────
# AI Core credentials are automatically injected via platform Service Binding
# (VCAP_SERVICES on Cloud Foundry, or K8s Secret on Kyma/BTP Runtime).
# Do NOT set AICORE_* variables manually — set_aicore_config() in main.py
# will auto-detect the binding at startup.

# Agent server
HOST=0.0.0.0
PORT=5000

# ── OpenTelemetry ─────────────────────────────────────────────────────────
OTEL_METRICS_EXPORTER=none
OTEL_TRACES_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# ── Email Notifications ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=btp-agent@yourcompany.com
EMAIL_TO=admin@yourcompany.com        # comma-separated for multiple recipients

# ── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULER_REPORT_HOUR=6               # UTC hour to send daily report (default: 6am)

# ── Annual Contract Quota (used by check_quota_status and daily report) ───
CONTRACT_CU=100000                    # Total CU purchased in contract
CONTRACT_START=2026-01-01             # Contract start date YYYY-MM-DD
CONTRACT_END=2026-12-31               # Contract end date YYYY-MM-DD
